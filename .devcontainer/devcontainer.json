{
    "name": "InstaInsight Codespace",
    "build": {
        "dockerfile": "Dockerfile",
        "context": ".."
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "dbaeumer.vscode-eslint",
                "esbenp.prettier-vscode",
                "ms-python.python",
                "ms-python.vscode-pylint",
                "ms-vscode.live-server"
            ]
        }
    },
    "forwardPorts": [
        3000,
        5173,
        8090
    ],
    "remoteUser": "root"
}