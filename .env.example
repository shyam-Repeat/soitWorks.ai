# Frontend (Vite) environment variables.
# Vercel exposes these as `VITE_` entries when deploying the UI separately from the backend.

# Backend API host (leave empty during local `npm run dev` so the UI talks to the same origin).
VITE_API_BASE_URL=""

# Optional front-end-only copy of the Gemini key if you ever need to hydrate the UI directly.
# Most calls currently go through the backend, so keep this blank unless a component needs it.
VITE_GEMINI_API_KEY=""
