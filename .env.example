# OLLAMA_MODEL: Local model name (e.g., llama3.2, mistral)
OLLAMA_MODEL="gemma3:4b"

# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY=""

# GROQ_API_KEY: Extremely fast alternative.
# Get it from https://console.groq.com/keys
GROQ_API_KEY=""

HF_API_KEY = ""

# APP_URL: The URL where this applet is hosted.
APP_URL="http://localhost:3000"

# APIFY_API_TOKEN: Required for scraping Instagram data.
APIFY_API_TOKEN=""

# POCKETBASE_URL: PocketBase server URL
# Local: http://127.0.0.1:8090
# Codespace: Update to your forwarded port URL
POCKETBASE_URL="http://127.0.0.1:8090"

# Scraping mode toggles (1=on, 0=off)
# Master toggles
SCRAPLING_ENABLE=1
APIFY_ENABLE=1

# If SCRAPLING_LEGACY_STABLE_MODE=1, it overrides SCRAPLING_ADVANCED_MODE.
SCRAPLING_LEGACY_STABLE_MODE=1
SCRAPLING_ADVANCED_MODE=0
SCRAPLING_ENABLE_APIFY_FALLBACK=1
